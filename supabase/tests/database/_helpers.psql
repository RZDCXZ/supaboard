create schema if not exists tests;

create or replace function tests.user_id(actor_name text)
returns uuid
language sql
immutable
set search_path = ''
as $$
  select case lower(actor_name)
    when 'alice' then '00000000-0000-4000-8000-000000000011'::uuid
    when 'bob' then '00000000-0000-4000-8000-000000000012'::uuid
    when 'charlie' then '00000000-0000-4000-8000-000000000013'::uuid
    else null
  end;
$$;

create or replace function tests.workspace_id(workspace_name text)
returns uuid
language sql
immutable
set search_path = ''
as $$
  select case lower(workspace_name)
    when 'alpha' then '00000000-0000-4000-8000-000000000101'::uuid
    when 'beta' then '00000000-0000-4000-8000-000000000102'::uuid
    else null
  end;
$$;

create or replace function tests.authenticate_as(actor_name text)
returns void
language plpgsql
set search_path = ''
as $$
declare
  actor_id uuid;
begin
  actor_id := tests.user_id(actor_name);

  if actor_id is null then
    raise exception 'unknown test actor: %', actor_name;
  end if;

  perform set_config('request.jwt.claim.sub', actor_id::text, true);
  perform set_config('request.jwt.claim.role', 'authenticated', true);
end;
$$;

create or replace function tests.clear_authentication()
returns void
language sql
set search_path = ''
as $$
  select set_config('request.jwt.claim.sub', '', true);
  select set_config('request.jwt.claim.role', 'anon', true);
$$;

grant usage on schema tests to anon, authenticated;
grant execute on all functions in schema tests to anon, authenticated;
